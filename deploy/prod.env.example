WEB_PORT=18080

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=mashinalar

# Use docker service name "postgres" (not localhost) inside compose network.
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/mashinalar?schema=public
REDIS_URL=redis://redis:6379

JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_EXPIRES_IN=7d

# Allow your prod domain to call API (cookies enabled in code).
CORS_ORIGIN=https://mashina.liderplast.uz
