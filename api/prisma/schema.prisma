generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DRIVER
  OPERATOR
}

enum TaskStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  role         UserRole
  login        String   @unique
  passwordHash String
  /// Lavozim (asosan OPERATOR uchun)
  position     String?
  /// Admin panel sahifalari kalitlari (faqat OPERATOR)
  allowedPages String[] @default([])
  /// Token "avlodi": adminda "Hammasini chiqarish" bossa oshiriladi va eski tokenlar ишламайди.
  tokenEpoch   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  driver Driver?
  auditLogs AuditLog[]
  sessions  UserSession[]
  sessionEvents UserSessionEvent[]
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// sha256(ip + '|' + userAgent) — bir xil qurilma/IP/UA = bitta yozuv
  fingerprint String
  ip          String?
  userAgent   String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  /// Admin tomonidan chiqarib yuborilgan vaqt; bu sessiya bilan request kelsa 401.
  revokedAt   DateTime?

  @@unique([userId, fingerprint])
  @@index([userId, lastSeenAt])
}

/// Ilova faol vaqti hisobi uchun (GPS / kirish pinglari).
model UserSessionEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint String?
  deviceLabel String?
  recordedAt  DateTime @default(now())

  @@index([userId, recordedAt])
}

model Driver {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String
  phone     String
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments DriverVehicleAssignment[]
  locationPoints LocationPoint[]
  fuelReports       FuelReport[]
  dailyKmReports    DailyKmReport[]
  tasks             Task[]
  oilChangeReports  OilChangeReport[]
  gpsOffSegments    GpsOffSegment[]

  @@index([vehicleId])
}

model Vehicle {
  id                   String    @id @default(cuid())
  name                 String
  model                String?
  plateNumber          String    @unique
  categoryId           String?
  category             VehicleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  initialKm            Decimal   @db.Decimal(12, 2)
  lastOilChangeKm      Decimal?  @db.Decimal(12, 2)
  lastOilChangeAt      DateTime?
  oilChangeIntervalKm  Int?
  insuranceStartDate   DateTime?
  insuranceEndDate     DateTime?
  inspectionStartDate  DateTime?
  inspectionEndDate    DateTime?
  inspectionLastChangedAt DateTime?
  inspectionNextChangeAt  DateTime?
  gasStartDate         DateTime?
  gasEndDate           DateTime?
  gasBalloonLastChangedAt DateTime?
  gasBalloonNextChangeAt  DateTime?
  /// Газ (1 м³) нархи (заправка суммасидан m³ hisoblash)
  gasPricePerM3        Decimal?  @db.Decimal(14, 2)
  /// Benzin (1 L) narxi
  petrolPricePerLiter  Decimal?  @db.Decimal(14, 2)
  lastLatitude         Decimal?  @db.Decimal(10, 7)
  lastLongitude        Decimal?  @db.Decimal(10, 7)
  lastLocationAt       DateTime?
  /// Soft delete: tarix (kun km, zapravka va h.k.) saqlanadi.
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  drivers        Driver[]
  assignments    DriverVehicleAssignment[]
  locationPoints LocationPoint[]
  fuelReports       FuelReport[]
  dailyKmReports    DailyKmReport[]
  tasks             Task[]
  expenses          Expense[]
  oilChangeReports  OilChangeReport[]
  gpsOffSegments    GpsOffSegment[]
  fuelStationMonthActuals FuelStationMonthActual[]

  @@index([categoryId])
  @@index([deletedAt])
}

model GpsOffSegment {
  id         String   @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId   String?
  driver     Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  startedAt  DateTime
  endedAt    DateTime
  createdAt  DateTime @default(now())

  @@unique([vehicleId, startedAt, endedAt])
  @@index([vehicleId, startedAt])
}

model VehicleCategory {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles Vehicle[]
}

model DriverVehicleAssignment {
  id             String   @id @default(cuid())
  driverId       String?
  driver         Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  /// Haydovchi o‘chirilganda tarix uchun saqlanadi.
  driverFullName String?
  driverPhone    String?
  vehicleId      String
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  startAt        DateTime @default(now())
  endAt          DateTime?
  createdAt      DateTime @default(now())

  @@index([driverId, startAt])
  @@index([vehicleId, startAt])
  @@index([endAt])
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  expenses Expense[]
}

model LocationPoint {
  id         String   @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId   String?
  driver     Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  accuracyM  Float?
  speed      Float?
  heading    Float?
  recordedAt DateTime @default(now())

  @@index([vehicleId, recordedAt])
  @@index([recordedAt])
}

model SavedFuelStation {
  id           String       @id @default(cuid())
  name         String
  latitude     Decimal      @db.Decimal(10, 7)
  longitude    Decimal      @db.Decimal(10, 7)
  radiusMeters Int          @default(500)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  fuelReports  FuelReport[]
  monthActuals FuelStationMonthActual[]
  vedomostSnapshots FuelVedomostSnapshot[]
}

enum FuelKind {
  GAS
  PETROL
}

model FuelReport {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId    String?
  driver      Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  /// Haydovchi o‘chirilganda tarix uchun saqlanadi.
  driverFullName String?
  fuelKind    FuelKind @default(GAS)
  /// Haydovchi kiritgan 1 m³ yoki 1 L narxi (admin defaultdan farq qilishi mumkin)
  unitPrice   Decimal? @db.Decimal(14, 4)
  /// amount / unitPrice — m³ yoki L
  volume      Decimal? @db.Decimal(14, 4)
  amount      Decimal  @db.Decimal(14, 2)
  currency    String   @default("UZS")
  vehiclePhotoUrl String?
  receiptPhotoUrl String?
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  savedFuelStationId String?
  savedFuelStation   SavedFuelStation? @relation(fields: [savedFuelStationId], references: [id], onDelete: SetNull)
  stationLabel       String?
  createdAt   DateTime @default(now())

  @@index([vehicleId, createdAt])
  @@index([driverId])
  @@index([savedFuelStationId])
}

/// Zapravка ведомость: ой бўйича кунларга бўлиб, ходим / тизимдан ташқари «ҳақиқий» м³
model FuelStationMonthActual {
  id                 String           @id @default(cuid())
  savedFuelStationId String
  savedFuelStation   SavedFuelStation @relation(fields: [savedFuelStationId], references: [id], onDelete: Cascade)
  vehicleId          String
  vehicle            Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  year               Int
  month              Int
  day                Int
  actualM3           Decimal          @db.Decimal(14, 4)
  /// Kiritilgan vaqtdagi gaz narxi bo‘yicha summa (m³ × narx)
  actualAmount       Decimal?         @db.Decimal(14, 2)
  updatedAt          DateTime         @updatedAt

  @@unique([savedFuelStationId, vehicleId, year, month, day])
  @@index([savedFuelStationId, year, month])
}

/// Ведомость тарихи: ойлик жадвалнинг бир вақтдаги нусхаси (Excel учун)
model FuelVedomostSnapshot {
  id                 String           @id @default(cuid())
  savedFuelStationId String
  savedFuelStation   SavedFuelStation @relation(fields: [savedFuelStationId], references: [id], onDelete: Cascade)
  year               Int
  month              Int
  createdAt          DateTime         @default(now())
  payload            Json

  @@index([savedFuelStationId, year, month, createdAt])
}

model OilChangeReport {
  id         String   @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId   String?
  driver     Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  /// Haydovchi o‘chirilganda tarix uchun saqlanadi.
  driverFullName String?
  kmAtChange Decimal  @db.Decimal(12, 2)
  photoUrl   String?
  createdAt  DateTime @default(now())

  @@index([vehicleId, createdAt])
  @@index([driverId])
}

model DailyKmReport {
  id              String   @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId        String?
  driver          Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  /// Haydovchi o‘chirilganda tarix uchun saqlanadi.
  driverFullName  String?
  reportDate      DateTime @db.Date
  startKm         Decimal  @db.Decimal(12, 2)
  endKm           Decimal? @db.Decimal(12, 2)
  startOdometerUrl String?
  endOdometerUrl   String?
  startLatitude    Decimal? @db.Decimal(10, 7)
  startLongitude   Decimal? @db.Decimal(10, 7)
  startRecordedAt  DateTime?
  endLatitude      Decimal? @db.Decimal(10, 7)
  endLongitude     Decimal? @db.Decimal(10, 7)
  endRecordedAt    DateTime?
  createdAt       DateTime @default(now())

  @@unique([vehicleId, reportDate])
  @@index([driverId])
}

model Task {
  id          String     @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId    String
  driver      Driver     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  title       String
  deadlineAt  DateTime
  status      TaskStatus @default(PENDING)
  note        String?
  proofPhotoUrl String?
  proofText   String?
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([deadlineAt])
  @@index([driverId, status])
}

model Expense {
  id         String           @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  categoryId String
  category   ExpenseCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amount     Decimal          @db.Decimal(14, 2)
  currency   String           @default("UZS")
  note       String?
  spentAt    DateTime         @default(now())
  createdAt  DateTime         @default(now())

  @@index([vehicleId, spentAt])
  @@index([categoryId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorUserId String?
  actor      User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action     String
  entity     String
  entityId   String?
  meta       Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}
